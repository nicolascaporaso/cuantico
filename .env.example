# Copia este fichero a `.env` en la raíz del repo y rellena los valores.
# `.env` está en .gitignore — nunca se subirá al repo.

# ------- LLM -------
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ------- TTS -------
# https://elevenlabs.io  →  Profile → API Keys
ELEVENLABS_API_KEY=
# Voice ID por defecto (puedes clonar la tuya en ElevenLabs y pegar aquí su ID)
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ------- STT / wake word -------
# https://console.deepgram.com  → API Keys (free tier sobra)
DEEPGRAM_API_KEY=
# Ruta absoluta al modelo .onnx de openWakeWord. Entrena el tuyo en
# https://github.com/dscripka/openWakeWord o usa uno de los pre-entrenados.
# Ejemplo Pi:  /home/pi/Cuantico/cuantico.onnx
# Ejemplo Mac: /Users/tu_usuario/Cuantico/cuantico.onnx
WAKE_MODEL_PATH=

# ------- Casa: luces Govee -------
# https://developer.govee.com  → solicitar key (llega por email)
GOVEE_API_KEY=

# ------- Música: Spotify -------
# https://developer.spotify.com/dashboard  → Create app
# Añade http://127.0.0.1:8888/callback como Redirect URI en la app
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ------- Google OAuth (Calendar + YouTube comparten Client ID tipo Desktop) -------
# 1. Console: https://console.cloud.google.com/apis/credentials
# 2. Create credentials → OAuth client ID → Desktop app
# 3. Descarga el JSON y guárdalo como state/google_client.json
# 4. La primera ejecución abrirá el navegador y generará state/google_token.json
GOOGLE_CLIENT_SECRETS_PATH=state/google_client.json
GOOGLE_TOKEN_PATH=state/google_token.json
# Vacío = usa el canal del usuario autenticado
YOUTUBE_CHANNEL_ID=
