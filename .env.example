# Copia este fichero a `.env` en la raíz del repo y rellena los valores.
# `.env` está en .gitignore — nunca se subirá al repo.

# ------- Usuario -------
USER_SHORT_NAME=Nico
USER_FULL_NAME=Nicolas
CUANTICO_PROFILE=argentino
CUANTICO_TIMEZONE=America/Argentina/Buenos_Aires

# ------- Audio local / Bluetooth -------
# Salida local por defecto de la VoiceHAT / I2S.
ALSA_PLAYBACK_DEVICE=plughw:0,0
# Si conectas un parlante Bluetooth compatible, Cuántico lo usa automáticamente.
BLUETOOTH_AUTO_ROUTE=true
# Perfil BlueALSA esperado para el parlante Bluetooth.
BLUETOOTH_AUDIO_PROFILE=a2dp
# Segundos de escaneo cuando pidas buscar parlantes Bluetooth.
BLUETOOTH_SCAN_SECONDS=8

# ------- LLM -------
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_CALL_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=

# ------- TTS -------
# https://elevenlabs.io  →  Profile → API Keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ------- STT / wake word -------
# https://console.deepgram.com  → API Keys (free tier sobra)
DEEPGRAM_API_KEY=
# Ruta absoluta al modelo .onnx de openWakeWord.
WAKE_MODEL_PATH=

# ------- Casa: luces Govee -------
# https://developer.govee.com  → solicitar key (llega por email)
GOVEE_API_KEY=
# Opcional: broadcast específico para descubrir luces WiZ, ej. 192.168.1.255
WIZ_BROADCAST_SPACE=

# ------- Música: Spotify -------
# https://developer.spotify.com/dashboard  → Create app
# Añade http://127.0.0.1:8888/callback como Redirect URI en la app
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ------- Música: backend general -------
# Backend preferido para los comandos generales de música: spotify o youtube
MUSIC_BACKEND_DEFAULT=spotify
# Binarios usados por el backend de YouTube
YT_DLP_COMMAND=yt-dlp
MPV_COMMAND=mpv
# Cuántos resultados analiza Cuántico al buscar una canción o playlist en YouTube
YOUTUBE_AUDIO_SEARCH_LIMIT=5
YOUTUBE_PLAYLIST_SEARCH_LIMIT=8

# ------- Google OAuth (Calendar + YouTube comparten Client ID tipo Desktop) -------
GOOGLE_CLIENT_SECRETS_PATH=state/google_client.json
GOOGLE_TOKEN_PATH=state/google_token.json
YOUTUBE_CHANNEL_ID=
